# 本地开发用：把此文件复制为 .env 并填入真实值
# 格式：KEY="VALUE" （值带特殊字符时务必用双引号包裹）
# 生产环境不要依赖此文件，请用 `wrangler secret put TIDB_DATABASE_URL`
# 或在 Cloudflare Dashboard → Worker → Settings → Variables and Secrets 设置

# TiDB Cloud Serverless 连接串
# 从 TiDB Cloud 控制台 → Connect → "Serverless Driver (HTTP)" 标签获取
# 形如：mysql://<user>:<pass>@gateway01.<region>.prod.aws.tidbcloud.com:4000/<db>?ssl={"rejectUnauthorized":true}
TIDB_DATABASE_URL="mysql://xxxxxxxxxxxxxxxxxxxxxxxx.gateway.<region>.prod.aws.tidbcloud.com:4000/test?ssl=%7B%22rejectUnauthorized%22%3Atrue%7D"
